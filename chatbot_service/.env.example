COHERE_API_KEY=your-cohere-api-key
COHERE_MODEL=command-a-03-2025
COHERE_TEMPERATURE=0.3
COHERE_MAX_TOKENS=800

JWT_SECRET=replace-with-a-random-32-byte-string
JWT_ALGORITHM=HS256

FRAPPE_URL=http://erpnext.localhost:8000
FRAPPE_HOST_HEADER=

CORS_ORIGINS=["http://erpnext.localhost:8000","http://localhost:8000"]

# RAG / pgvector
DATABASE_URL=postgresql://custom_dashboard:change-me@127.0.0.1:5432/custom_dashboard_rag
RAG_INTERNAL_API_KEY=replace-with-a-long-random-internal-key
RAG_EMBED_MODEL=embed-multilingual-v3.0
RAG_RERANK_MODEL=rerank-v3.5
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=24
RAG_RERANK_TOP_N=8
RAG_MIN_RELEVANCE=0.15
RAG_DB_POOL_SIZE=5
RAG_CHAT_ENABLED=true

# Voice (local Piper TTS + faster-whisper STT via voice-gateway)
VOICE_ENABLED=true
VOICE_GATEWAY_URL=http://127.0.0.1:8010
VOICE_GATEWAY_TIMEOUT=60
STT_MAX_BYTES=26214400
